{%- comment -%}
Custom Product Builder Product Card Snippet
- Handles all product card UI and logic
- Receives settings as variables
{%- endcomment -%}

{%- assign first_image = product.featured_image | default: product.images.first -%}
{%- assign second_image = product.images[1] -%}

<div class="cpb-card" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
  <div class="cpb-card__image-wrapper">
    <a href="{{ product.url }}" class="cpb-card__image-link">
      <img class="cpb-card__image cpb-card__image--primary" src="{{ first_image | image_url: width: 600 }}" alt="{{ product.title | escape }}">
      {% if second_image %}
        <img class="cpb-card__image cpb-card__image--secondary" src="{{ second_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy">
      {% endif %}
      {% if enable_sale_badge and product.compare_at_price > product.price %}
        <span class="cpb-card__badge cpb-card__badge--sale">Sale</span>
      {% endif %}
    </a>
    {% if enable_stock_message and product.variants.first.inventory_management and product.variants.first.inventory_quantity > 0 and product.variants.first.inventory_quantity <= 5 %}
      <span class="cpb-card__stock">Only {{ product.variants.first.inventory_quantity }} left</span>
    {% endif %}
  </div>
  <div class="cpb-card__info">
    <div class="cpb-card__title-row">
      <a href="{{ product.url }}" class="cpb-card__title">{{ product.title }}</a>
      {% if show_vendor %}
        <span class="cpb-card__vendor">{{ product.vendor }}</span>
      {% endif %}
    </div>
    <div class="cpb-card__price-row">
      <span class="cpb-card__price" data-price>{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="cpb-card__compare" data-compare>{{ product.compare_at_price | money }}</span>
      {% endif %}
    </div>
    {% if show_rating %}
      <div class="cpb-card__rating">★★★★★</div>
    {% endif %}
    <form class="cpb-card__form" data-product-form>
      {% if product.variants.size > 1 %}
        <div class="cpb-card__variants">
          <label for="cpb-variant-{{ product.id }}">Options:</label>
          <select id="cpb-variant-{{ product.id }}" name="id" class="cpb-card__variant-select" data-variant-select>
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% if variant.available == false %}disabled{% endif %} data-price="{{ variant.price }}" data-compare="{{ variant.compare_at_price }}" data-sale="{{ variant.compare_at_price > variant.price }}" data-available="{{ variant.available }}">
                {{ variant.title }} {% unless variant.available %}(Sold out){% endunless %}
              </option>
            {% endfor %}
          </select>
        </div>
      {% else %}
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      {% endif %}
      <div class="cpb-card__qty">
        <label for="cpb-qty-{{ product.id }}">Qty:</label>
        <input id="cpb-qty-{{ product.id }}" name="quantity" type="number" min="1" value="1" class="cpb-card__qty-input">
      </div>
      {% if show_quick_add %}
        <button type="submit" class="cpb-card__add-btn" data-add-to-cart>Add to cart</button>
        <span class="cpb-card__loading" hidden>Adding...</span>
        <span class="cpb-card__success" hidden>Added!</span>
        <span class="cpb-card__error" hidden>Error!</span>
      {% endif %}
    </form>
    <div class="cpb-card__availability" data-availability>
      {% if product.available %}In stock{% else %}Sold out{% endif %}
    </div>
  </div>
</div>

<style>
.cpb-card {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 18px;
  box-shadow: 0 6px 32px 0 rgba(60, 72, 88, 0.13), 0 1.5px 6px 0 rgba(60, 72, 88, 0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.35s cubic-bezier(.4,2,.6,1), transform 0.25s cubic-bezier(.4,2,.6,1);
  will-change: box-shadow, transform;
  position: relative;
}
.cpb-card:hover {
  box-shadow: 0 12px 40px 0 rgba(60, 72, 88, 0.18), 0 3px 12px 0 rgba(60, 72, 88, 0.10);
  transform: translateY(-6px) scale(1.025);
  z-index: 2;
}
.cpb-card__image-wrapper {
  position: relative;
  overflow: hidden;
  background: linear-gradient(120deg, #e0e7ff 0%, #f0fdfa 100%);
  min-height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cpb-card__image {
  width: 100%;
  display: block;
  transition: opacity 0.4s cubic-bezier(.4,2,.6,1), transform 0.4s cubic-bezier(.4,2,.6,1);
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(60, 72, 88, 0.07);
}
.cpb-card__image--secondary {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0;
  pointer-events: none;
}
.cpb-card__image-wrapper:hover .cpb-card__image--secondary {
  opacity: 1;
  transform: scale(1.04) rotate(-1deg);
}
.cpb-card__image-wrapper:hover .cpb-card__image--primary {
  opacity: 0;
  transform: scale(0.98) rotate(1deg);
}
.cpb-card__badge--sale {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background: linear-gradient(90deg, #ff5858 0%, #ffb347 100%);
  color: #fff;
  font-size: 0.92rem;
  padding: 0.32em 1em;
  border-radius: 2em;
  box-shadow: 0 2px 8px rgba(255, 88, 88, 0.13);
  font-weight: 700;
  letter-spacing: 0.03em;
  z-index: 2;
  animation: popIn 0.7s cubic-bezier(.4,2,.6,1);
}
.cpb-card__stock {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  background: #fffbe6;
  color: #b26a00;
  font-size: 0.92rem;
  padding: 0.32em 1em;
  border-radius: 2em;
  box-shadow: 0 2px 8px rgba(255, 215, 64, 0.13);
  font-weight: 600;
  z-index: 2;
  animation: popIn 0.7s cubic-bezier(.4,2,.6,1);
}
@keyframes popIn {
  0% { transform: scale(0.7); opacity: 0; }
  80% { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}
.cpb-card__info {
  padding: 1.3rem 1.2rem 1.2rem 1.2rem;
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.cpb-card__title-row {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  justify-content: space-between;
}
.cpb-card__title {
  font-weight: 700;
  color: #1e293b;
  text-decoration: none;
  font-size: 1.13rem;
  letter-spacing: 0.01em;
  transition: color 0.2s;
}
.cpb-card__title:hover {
  color: #6366f1;
}
.cpb-card__vendor {
  font-size: 0.97em;
  color: #64748b;
  font-weight: 500;
}
.cpb-card__price-row {
  display: flex;
  align-items: baseline;
  gap: 0.6rem;
}
.cpb-card__price {
  font-weight: 800;
  color: #0f172a;
  font-size: 1.15rem;
  letter-spacing: 0.01em;
}
.cpb-card__compare {
  text-decoration: line-through;
  color: #b0b0b0;
  font-size: 1.02em;
  font-weight: 500;
}
.cpb-card__rating {
  color: #ffb400;
  font-size: 1.18em;
  letter-spacing: 0.04em;
  filter: drop-shadow(0 1px 2px #fff3);
}
.cpb-card__form {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  flex-wrap: wrap;
  margin-top: 0.3rem;
}
.cpb-card__variants {
  flex: 1 1 100%;
}
.cpb-card__variant-select {
  width: 100%;
  padding: 0.38em 0.5em;
  border-radius: 8px;
  border: 1px solid #e0e7ef;
  background: #f8fafc;
  font-size: 1em;
  transition: border 0.2s;
}
.cpb-card__variant-select:focus {
  border-color: #6366f1;
  outline: none;
}
.cpb-card__qty {
  width: 80px;
}
.cpb-card__qty-input {
  width: 54px;
  padding: 0.32em 0.5em;
  border-radius: 8px;
  border: 1px solid #e0e7ef;
  background: #f8fafc;
  font-size: 1em;
  transition: border 0.2s;
}
.cpb-card__qty-input:focus {
  border-color: #6366f1;
  outline: none;
}
.cpb-card__add-btn {
  background: linear-gradient(90deg, #6366f1 0%, #38bdf8 100%);
  color: #fff;
  border: none;
  padding: 0.6em 1.5em;
  border-radius: 2em;
  cursor: pointer;
  font-weight: 700;
  font-size: 1.05em;
  box-shadow: 0 2px 8px rgba(99,102,241,0.08);
  transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
  letter-spacing: 0.01em;
}
.cpb-card__add-btn:hover:not([disabled]) {
  background: linear-gradient(90deg, #38bdf8 0%, #6366f1 100%);
  box-shadow: 0 4px 16px rgba(56,189,248,0.13);
  transform: scale(1.04);
}
.cpb-card__add-btn[disabled] {
  background: #cbd5e1;
  color: #fff;
  cursor: not-allowed;
  box-shadow: none;
}
.cpb-card__loading,
.cpb-card__success,
.cpb-card__error {
  font-size: 1em;
  margin-left: 0.7em;
  font-weight: 500;
}
.cpb-card__success { color: #22c55e; }
.cpb-card__error { color: #e11d48; }
.cpb-card__availability {
  font-size: 1em;
  color: #64748b;
  margin-top: 0.7em;
  font-weight: 500;
}
@media (max-width: 600px) {
  .cpb-card__info {
    padding: 1rem 0.7rem 1rem 0.7rem;
  }
  .cpb-card__title {
    font-size: 1.01rem;
  }
  .cpb-card__price {
    font-size: 1.01rem;
  }
}
</style>
