<div id="custom-product-builder-{{ section.id }}" class="custom-product-builder-section" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="custom-product-builder__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="custom-product-builder__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="custom-product-builder__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  {%- assign selected_collection = collections[section.settings.collection] -%}
  {%- if section.settings.collection == blank or selected_collection == nil -%}
    <div class="custom-product-builder__empty">
      <p>Please select a collection in the section settings.</p>
    </div>
  {%- elsif selected_collection.products_count == 0 -%}
    <div class="custom-product-builder__empty">
      <p>No products found in the selected collection.</p>
    </div>
  {%- else -%}
    <div class="custom-product-builder__grid columns-{{ section.settings.grid_columns }}">
      {%- for product in selected_collection.products limit: section.settings.products_to_show -%}
        {%- render 'custom-product-builder-card',
          product: product,
          show_vendor: section.settings.show_vendor,
          show_rating: section.settings.show_rating,
          show_quick_add: section.settings.show_quick_add,
          enable_sale_badge: section.settings.enable_sale_badge,
          enable_stock_message: section.settings.enable_stock_message
        -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<style>
/* Inline CSS for section styling and responsiveness */
.custom-product-builder-section {
  padding: 3rem 1.5rem;
  max-width: 1200px;
  margin: 0 auto;
}
.custom-product-builder__header {
  text-align: center;
  margin-bottom: 2.5rem;
}
.custom-product-builder__heading {
  font-size: 2.25rem;
  margin: 0 0 0.75rem 0;
  font-weight: 600;
}
.custom-product-builder__subtitle {
  font-size: 1.15rem;
  margin: 0;
  color: inherit;
  opacity: 0.8;
}
.custom-product-builder__grid {
  display: grid;
  gap: 2rem;
}
.custom-product-builder__grid.columns-2 {
  grid-template-columns: repeat(2, 1fr);
}
.custom-product-builder__grid.columns-3 {
  grid-template-columns: repeat(3, 1fr);
}
.custom-product-builder__grid.columns-4 {
  grid-template-columns: repeat(4, 1fr);
}
@media (max-width: 990px) {
  .custom-product-builder__grid.columns-3,
  .custom-product-builder__grid.columns-4 {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 768px) {
  .custom-product-builder__grid {
    grid-template-columns: 1fr !important;
  }
  .custom-product-builder__heading {
    font-size: 1.75rem;
  }
}
.custom-product-builder__empty {
  text-align: center;
  color: #888;
  padding: 3rem 0;
  border: 1px dashed #ddd;
  border-radius: 4px;
}
</style>

<script src="{{ 'custom-product-builder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Custom Product Builder",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Build Your Product"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section subtitle",
      "default": "Customize and add to cart instantly."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of products to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#222222"
    },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Grid layout (columns)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show product rating placeholder",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sale_badge",
      "label": "Enable sale badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_stock_message",
      "label": "Enable 'Only X left' stock message",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Custom Product Builder"
    }
  ]
}
{% endschema %}